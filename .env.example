# Postgres
POSTGRES_USER=firedrill
POSTGRES_PASSWORD=firedrill
POSTGRES_DB=firedrill
DATABASE_URL=postgres://firedrill:firedrill@postgres:5432/firedrill

# Redis
REDIS_URL=redis://redis:6379

# API
API_PORT=4000
API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Worker
WORKER_METRICS_PORT=4001

# Logging
LOG_LEVEL=info

# Optional LLM for incident reports (project works without it)
OPENAI_API_KEY=
